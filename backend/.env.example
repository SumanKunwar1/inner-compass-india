# Copy to .env and fill in real values. Never commit .env.

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/btmc?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Seeded admin account
ADMIN_EMAIL=admin@btmcfoundation.in
ADMIN_PASSWORD=change-me

# CORS — comma separated list of allowed frontend origins.
# (In development any http://localhost:<port> is also accepted automatically.)
CORS_ORIGIN=http://localhost:8080,http://localhost:3000,http://localhost:5173

MAX_BODY_SIZE=10mb
